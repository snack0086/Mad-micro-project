<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D3E8DA"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Main Logo Container with Shadow -->
    <androidx.cardview.widget.CardView
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white"
        app:cardMaxElevation="15dp"
        app:strokeWidth="4dp"
        app:strokeColor="#1A3A4A"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/splash1_circle_light_bg"
            android:padding="20dp">

            <!-- Modern Building Icon -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/splash2_ic_modern_campus"
                android:layout_marginBottom="12dp"/>

            <!-- Logo Text with Theme Color -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAMPUS"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A3A4A"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-black"
                android:lineHeight="26sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A3A4A"
                android:alpha="0.9"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:lineHeight="24sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Tagline with Theme Color Accent -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Campus, Connected"
        android:textSize="18sp"
        android:textColor="#1A3A4A"
        android:alpha="0.8"
        android:fontFamily="sans-serif"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:letterSpacing="0.05"/>

    <!-- Version with Theme Color -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="14sp"
        android:textColor="#1A3A4A"
        android:alpha="0.6"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.1"/>
    <!-- ===== Sleeker Alternative Design ===== -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">

        <!-- Progress Bar Track -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#B0D3C5"/>

        <!-- Animated Progress Indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#1A3A4A"
            android:indeterminate="true"
            android:indeterminateTint="#1A3A4A"
            android:visibility="visible"/>
    </FrameLayout>
</LinearLayout>