<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Assignment Title Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title with Theme Color -->
            <TextView
                android:id="@+id/tvTitle"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#1A3A4A"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assignment Title"/>

            <!-- Divider -->
            <View
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:background="#1A3A4A"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_marginTop="4dp"
                android:textSize="15sp"
                android:textColor="#333333"
                android:lineSpacingExtra="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assignment description goes here..."/>

            <!-- Submission Count with Theme Color -->
            <TextView
                android:id="@+id/tvSubmissionCount"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:textColor="#1A3A4A"
                android:background="#E8F0FE"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submissions: 0/30"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Submit Button with Theme Color -->
    <Button
        android:id="@+id/btnSubmit"
        android:text="Mark as Submitted"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A3A4A"
        app:cornerRadius="12dp"
        android:stateListAnimator="@null"/>

    <!-- Comments Section Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comments"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A3A4A"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="8dp"/>

    <!-- COMMENTS LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComments"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:nestedScrollingEnabled="false"/>

    <!-- Comment Input Section -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/etComment"
                android:hint="Write a comment..."
                android:padding="12dp"
                android:background="@drawable/login1_edittext_theme_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="#9AA6B2"
                android:textColor="#1A1C1E"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnComment"
                android:text="Post Comment"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A3A4A"
                app:cornerRadius="10dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>