<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Toolbar with direct color - NO DRAWABLE NEEDED -->
            <!-- Toolbar with ALL styling inline - Guaranteed to work -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="#1A3A4A">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assignments"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:layout_gravity="center"/>

            </androidx.appcompat.widget.Toolbar>

            <!-- RecyclerView with light background -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAssignments"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                android:background="#F5F5F5"/>

        </LinearLayout>

        <!-- FAB with theme color -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddAssignment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Add Assignment"
            app:backgroundTint="#1A3A4A"
            app:tint="#FFFFFF"
            android:elevation="8dp"/>

    </FrameLayout>

    <!-- NavigationView -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#1A3A4A"
        app:itemTextColor="#1A3A4A"
        app:itemTextAppearance="@style/TextAppearance.AppCompat.Body2"/>

</androidx.drawerlayout.widget.DrawerLayout>