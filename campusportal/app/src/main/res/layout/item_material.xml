<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Material Icon -->
<!--        <ImageView-->
<!--            android:id="@+id/ivMaterialIcon"-->
<!--            android:layout_width="48dp"-->
<!--            android:layout_height="48dp"-->
<!--            android:src="@drawable/ic_pdf"-->
<!--            android:padding="10dp" />-->

        <!-- Material Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Material Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvMaterialDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:maxLines="2"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvTeacher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher Name"
                android:textSize="12sp"
                android:textColor="#6B7280"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12/12/2026"
                android:textSize="12sp"
                android:textColor="#6B7280"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvFileType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDF"
                    android:textSize="11sp"
                    android:textColor="#1A3A4A"
                    android:background="#E6F0FA"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:radius="4dp"/>

                <TextView
                    android:id="@+id/tvFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.5 MB"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Download Button -->
        <ImageView
            android:id="@+id/btnDownload"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_download"
            android:padding="8dp"
            app:tint="#1A3A4A"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>