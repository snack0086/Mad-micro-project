<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOOLBAR with Theme Color -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A3A4A"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:title="My Profile"
            android:paddingTop="10dp"
            android:src="@drawable/styles"
            app:titleTextColor="@android:color/white"
            />

        <!-- YOUR ORIGINAL UI -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar"
            android:background="#F2F4F7"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Header with Back Button -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Campus Connect"
                                    android:textColor="#1A3A4A"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-black"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Profile Title -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="My Profile"
                            android:textColor="#1A3A4A"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1"/>

                        <!-- Divider -->
                        <View
                            android:layout_width="60dp"
                            android:layout_height="3dp"
                            android:background="#1A3A4A"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:gravity="center"
                            android:text="View and manage your personal information"
                            android:textColor="#74777F"
                            android:textSize="14sp" />

                        <!-- Profile Photo Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:layout_marginBottom="24dp">

                            <RelativeLayout
                                android:layout_width="120dp"
                                android:layout_height="120dp">

                                <ImageView
                                    android:id="@+id/ivProfilePhoto"
                                    android:layout_width="120dp"
                                    android:layout_height="120dp"
                                    android:background="@drawable/circle_shape"
                                    android:src="@drawable/ic_profile_placeholder"
                                    android:scaleType="centerCrop"
                                    android:padding="2dp"
                                    android:backgroundTint="#1A3A4A"/>

                                <ImageView
                                    android:id="@+id/btnEditPhoto"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:src="@drawable/ic_camera"
                                    android:background="@drawable/circle_white_bg"
                                    android:padding="8dp"
                                    android:elevation="4dp"
                                    app:tint="#1A3A4A"/>
                            </RelativeLayout>

                            <TextView
                                android:id="@+id/txtChangePhoto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Change Profile Photo"
                                android:textColor="#1A3A4A"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <!-- Profile Fields with Labels -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfileName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Jane Doe"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfileStudentId"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="12345678"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="University Email"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfileEmail"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="jane.doe@university.edu"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Department"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfileDepartment"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Computer Science"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year of Study"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfileYear"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="3rd Year"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phone Number"
                            android:textColor="#1A3A4A"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etProfilePhone"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="+1 234 567 8900"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="24dp"
                            android:enabled="false"
                            android:background="@drawable/disabled_edittext_bg"
                            android:textColor="#1A1C1E"/>

                        <!-- Edit/Save Button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="8dp">

                            <Button
                                android:id="@+id/btnEditProfile"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#1A3A4A"
                                android:text="Edit Profile"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="16dp"
                                android:stateListAnimator="@null"/>

                            <Button
                                android:id="@+id/btnSaveProfile"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="#44474F"
                                android:text="Save Changes"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                app:cornerRadius="16dp"
                                android:stateListAnimator="@null"/>
                        </LinearLayout>

                        <!-- Bottom Links -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:orientation="horizontal"
                            android:layout_gravity="center"
                            android:layout_marginTop="8dp"
                            android:background="#F5F7FA"
                            android:padding="8dp"
                            android:radius="12dp">

                            <TextView
                                android:id="@+id/txtChangePassword"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Change Password"
                                android:textColor="#1A3A4A"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:clickable="true"
                                android:focusable="true" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="30dp"
                                android:background="#E0E0E0"/>

                            <TextView
                                android:id="@+id/txtLogout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Logout"
                                android:textColor="#E63946"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

    </RelativeLayout>

    <!-- DRAWER MENU -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#1A3A4A"
        app:itemTextColor="#1A3A4A"/>

</androidx.drawerlayout.widget.DrawerLayout>