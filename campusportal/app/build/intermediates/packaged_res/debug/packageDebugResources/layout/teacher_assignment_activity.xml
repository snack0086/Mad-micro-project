<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F7FA">

        <!-- HEADER with Theme Color Gradient -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A3A4A"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:background="@drawable/splash1_circle_light_bg"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="39dp"
                    android:src="@drawable/splash2_ic_modern_campus" />  <!-- Theme color icon, not white -->
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus Connect Portal"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Page Title with Theme Color -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Assignment"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A4A"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"/>

                <!-- Divider -->
                <View
                    android:layout_width="60dp"
                    android:layout_height="3dp"
                    android:background="#1A3A4A"
                    android:layout_marginBottom="24dp"/>

                <!-- Assignment Title Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assignment Title"
                    android:textSize="14sp"
                    android:textColor="#1A3A4A"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"/>

                <EditText
                    android:id="@+id/etAssignmentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter assignment title"
                    android:padding="16dp"
                    android:background="@drawable/login1_edittext_theme_bg"
                    android:textColorHint="#9AA6B2"
                    android:textColor="#1A1C1E"
                    android:layout_marginBottom="16dp"/>

                <!-- Assignment Description Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assignment Description"
                    android:textSize="14sp"
                    android:textColor="#1A3A4A"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"/>

                <EditText
                    android:id="@+id/etAssignmentDesc"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:hint="Write detailed description here..."
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:background="@drawable/login1_edittext_theme_bg"
                    android:textColorHint="#9AA6B2"
                    android:textColor="#1A1C1E"
                    android:layout_marginBottom="20dp"/>

                <!-- Attach File Button with Theme Color -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAttachFile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Attach PDF / Image"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="#1A3A4A"
                    app:cornerRadius="12dp"
                    app:rippleColor="#B0D3E0"
                    android:layout_marginBottom="12dp"
                    android:stateListAnimator="@null"
                    android:elevation="2dp"/>

                <!-- Selected File Indicator -->
                <TextView
                    android:id="@+id/tvSelectedFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file selected"
                    android:textSize="14sp"
                    android:textColor="#1A3A4A"
                    android:alpha="0.7"
                    android:layout_marginBottom="24dp"
                    android:padding="12dp"
                    android:background="#F0F4F8"
                    android:gravity="center"
                    android:radius="8dp"/>

                <!-- Post Assignment Button with Theme Color -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPostAssignment"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Post Assignment"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="#1A3A4A"
                    app:cornerRadius="16dp"
                    app:rippleColor="#B0D3E0"
                    android:stateListAnimator="@null"
                    android:elevation="4dp"/>

                <!-- Cancel Option (Optional) -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textSize="14sp"
                    android:textColor="#1A3A4A"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.7"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- NavigationView with Theme Color Tint -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#1A3A4A"
        app:itemTextColor="#1A3A4A"/>

</androidx.drawerlayout.widget.DrawerLayout>